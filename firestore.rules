rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users: read own, write own
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /dailyNotes/{date} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Usernames: public read, create-once
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }
    
    // Habits: CRUD own, public read if enabled
    match /habits/{habitId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.userId == request.auth.uid || 
        (resource.data.status == "active" && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.publicProfile == true)
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    // Logs: CRUD own only
    match /logs/{logId} {
      // Allow get even if document doesn't exist yet (returns null resource)
      allow get: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      // Allow list (queries) only for own logs
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow writes only for own logs
      allow write: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        (request.resource != null && request.resource.data.userId == request.auth.uid)
      );
    }
    
    // Freezes: CRUD own only
    match /freezes/{freezeId} {
      allow get: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        (request.resource != null && request.resource.data.userId == request.auth.uid)
      );
    }

    match /habitArchives/{habitId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false; 
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}