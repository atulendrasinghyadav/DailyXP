rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public profile document: shareable, read/list for everyone (Wall of Fame).
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Match any document in the 'users' collection or its subcollections
    match /users/{userId}/{document=**} {
      
      // Allow read/write only if the user is authenticated 
      // AND their Firebase Auth UID matches the document's userId
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
